          "text" : {
            "type" : "interpolation",
            "value" : "<button class=\"btn btn-success btn-block\" type=\"button\" style=\"padding: 10px 20px; font-weight: bold;\" onclick=\"\n    // 1. Récupérer les données du formulaire via Angular\n    var scope = angular.element(document.getElementById('content')).scope() || angular.element(this).scope();\n    var dataToSend = scope.properties ? scope.properties.formOutput : null;\n    \n    if(!dataToSend) {\n        // Sécurité si le scope est imbriqué\n        var selectElem = document.querySelector('select');\n        if(selectElem) dataToSend = { 'choixRestoInput': selectElem.value };\n    }\n\n    // 2. Extraire l'ID de la tâche depuis l'URL actuelle\n    var urlTokens = window.location.href.split('/');\n    var taskId = urlTokens[urlTokens.indexOf('taskInstance') + 1];\n    \n    // 3. Forcer l'URL absolue propre sans le dossier parasite\n    var targetUrl = window.location.origin + '/bonita/API/bpm/userTask/' + taskId + '/execution';\n\n    // 4. Envoi de la requête POST manuelle\n    var xhr = new XMLHttpRequest();\n    xhr.open('POST', targetUrl, true);\n    xhr.setRequestHeader('Content-Type', 'application/json;charset=UTF-8');\n    \n    xhr.onreadystatechange = function () {\n        if (xhr.readyState === 4) {\n            if (xhr.status === 204 || xhr.status === 200) {\n                alert('Choix enregistré avec succès !');\n                // Redirige vers le portail pour rafraîchir la liste des tâches\n                window.location.href = window.location.origin + '/bonita';\n            } else {\n                alert('Erreur technique Bonita : ' + xhr.status + '\\nAssurez-vous d\\'avoir sélectionné une option.');\n            }\n        }\n    };\n    xhr.send(JSON.stringify(dataToSend));\n\">\n    Confirmer mon choix\n</button>"
          },
