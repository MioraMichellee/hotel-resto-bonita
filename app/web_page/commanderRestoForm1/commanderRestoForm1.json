    },
    "submitTaskManual" : {
      "type" : "expression",
      "value" : [
        "if ($data.formOutput) {\r",
        "    var xhr = new XMLHttpRequest();\r",
        "    // On extrait l'ID de la tâche depuis l'URL de la page actuelle\r",
        "    var urlTokens = window.location.href.split('/');\r",
        "    var taskId = urlTokens[urlTokens.indexOf('taskInstance') + 1];\r",
        "\r",
        "    var targetUrl = window.location.origin + '/bonita/API/bpm/userTask/' + taskId + '/execution';\r",
        "\r",
        "    xhr.open(\"POST\", targetUrl, true);\r",
        "    xhr.setRequestHeader(\"Content-Type\", \"application/json;charset=UTF-8\");\r",
        "\r",
        "    xhr.onreadystatechange = function () {\r",
        "        if (xhr.readyState === 4) {\r",
        "            if (xhr.status === 204 || xhr.status === 200) {\r",
        "                alert(\"Choix enregistré avec succès !\");\r",
        "                window.location.reload(); // Rafraîchit la page pour passer à la suite\r",
        "            } else {\r",
        "                alert(\"Erreur technique : \" + xhr.status + \" - \" + xhr.responseText);\r",
        "            }\r",
        "        }\r",
        "    };\r",
        "\r",
        "    xhr.send(JSON.stringify($data.formOutput));\r",
        "}\r",
        "return \"\";"
      ],
      "exposed" : false
    }
